// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  WORKER
}

enum UnitType {
  PIECE
  KILOGRAM
}

enum StockExitReason {
  EXPIRED
  DAMAGED
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  SUPPLIER_PAYMENT
  WITHDRAWAL
  EXPENSE
  CASH_IN
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

model User {
  id           String @id @default(cuid())
  fullName     String
  email        String @unique
  username     String? @unique
  passwordHash String
  phone        String
  role         Role   @default(WORKER)
  active       Boolean @default(true)
  sales        Sale[]
  canceledSales Sale[] @relation("SaleCanceledBy")
  heldTickets  HeldTicket[]
  stockExits   StockExit[]
  openedCashSessions CashRegisterSession[] @relation("CashRegisterOpenedBy")
  closedCashSessions CashRegisterSession[] @relation("CashRegisterClosedBy")
  cashMovements CashMovement[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  costPrice   Decimal  @default(0) @db.Decimal(10, 2)
  profitMargin Decimal @default(0) @db.Decimal(7, 2)
  price       Decimal  @db.Decimal(10, 2)
  unit        UnitType @default(PIECE)
  stock       Decimal  @default(0) @db.Decimal(12, 3)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  saleItems   SaleItem[]
  heldTicketItems HeldTicketItem[]
  stockExits  StockExit[]

  @@index([name])
  @@index([updatedAt, id])
  @@index([active, updatedAt])
  @@index([active, stock])
}

model StockExit {
  id          String          @id @default(cuid())
  productId   String?
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  reason      StockExitReason
  sku         String
  name        String
  description String?
  unit        UnitType
  quantity    Decimal         @db.Decimal(12, 3)
  note        String?
  createdAt   DateTime        @default(now())

  @@index([createdAt])
  @@index([productId])
  @@index([userId, createdAt])
}

model Sale {
  id        String     @id @default(cuid())
  folio     Int        @unique @default(autoincrement())
  total     Decimal    @db.Decimal(12, 2)
  paymentTotal Decimal? @db.Decimal(12, 2)
  itemCount Decimal    @db.Decimal(12, 3)
  paymentMethod PaymentMethod @default(CASH)
  cashReceived Decimal? @db.Decimal(12, 2)
  changeDue Decimal? @db.Decimal(12, 2)
  sellerId  String
  seller    User       @relation(fields: [sellerId], references: [id])
  cashSessionId String?
  cashSession   CashRegisterSession? @relation(fields: [cashSessionId], references: [id])
  canceledAt DateTime?
  canceledById String?
  canceledBy User? @relation("SaleCanceledBy", fields: [canceledById], references: [id])
  cancelReason String?
  items     SaleItem[]
  createdAt DateTime   @default(now())

  @@index([createdAt])
  @@index([sellerId, createdAt])
  @@index([canceledAt])
  @@index([canceledById, canceledAt])
  @@index([cashSessionId, createdAt])
  @@index([paymentMethod, createdAt])
}

model CashRegisterSession {
  id             String             @id @default(cuid())
  status         CashRegisterStatus @default(OPEN)
  openingAmount  Decimal            @db.Decimal(12, 2)
  closingAmount  Decimal?           @db.Decimal(12, 2)
  expectedAmount Decimal?           @db.Decimal(12, 2)
  difference     Decimal?           @db.Decimal(12, 2)
  openedById     String
  openedBy       User               @relation("CashRegisterOpenedBy", fields: [openedById], references: [id])
  closedById     String?
  closedBy       User?              @relation("CashRegisterClosedBy", fields: [closedById], references: [id])
  notes          String?
  openedAt       DateTime           @default(now())
  closedAt       DateTime?
  sales          Sale[]
  heldTickets    HeldTicket[]
  movements      CashMovement[]

  @@index([status, openedAt])
  @@index([openedById, openedAt])
  @@index([closedById, closedAt])
}

model CashMovement {
  id            String              @id @default(cuid())
  cashSessionId String
  cashSession   CashRegisterSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User                @relation(fields: [createdById], references: [id])
  type          CashMovementType
  amount        Decimal             @db.Decimal(12, 2)
  description   String
  createdAt     DateTime            @default(now())

  @@index([cashSessionId, createdAt])
  @@index([createdById, createdAt])
  @@index([type, createdAt])
}

model HeldTicket {
  id            String              @id @default(cuid())
  note          String?
  itemCount     Decimal             @db.Decimal(12, 3)
  total         Decimal             @db.Decimal(12, 2)
  paymentMethod PaymentMethod       @default(CASH)
  cashSessionId String
  cashSession   CashRegisterSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User                @relation(fields: [createdById], references: [id])
  items         HeldTicketItem[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([cashSessionId, createdAt])
  @@index([createdById, createdAt])
}

model HeldTicketItem {
  id          String     @id @default(cuid())
  heldTicketId String
  heldTicket   HeldTicket @relation(fields: [heldTicketId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku         String
  name        String
  description String?
  unit        UnitType
  quantity    Decimal    @db.Decimal(12, 3)
  unitPrice   Decimal    @db.Decimal(10, 2)
  lineTotal   Decimal    @db.Decimal(12, 2)

  @@index([heldTicketId])
  @@index([productId])
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku         String
  name        String
  description String?
  unit        UnitType
  quantity    Decimal  @db.Decimal(12, 3)
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)

  @@index([saleId])
  @@index([productId])
}
